generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum UserRole {
  USER
  BUSINESS
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum SessionRevokeReason {
  LOGOUT
  REUSE_DETECTED
  ADMIN_REVOKED
  PASSWORD_CHANGE
}

enum MediaStorageProvider {
  LOCAL
  S3
}

enum MediaResourceType {
  TRADE_POST
  TRADE_REVIEW
  USER_AVATAR
  BUSINESS_APPLICATION
  ABOUT
  TEMPLE
  SPECIALTY
  HISTORICAL_SITE
  AGRICULTURE
  OCOP
  CRAFT_VILLAGE
  CUISINE
  FESTIVAL
  EXPERIENCE_TOUR
  FEEDBACK_CHANNEL
  MAP_PLACE
  CONTACT
  NEWS_ARTICLE
}

enum TempleType {
  DINH
  CHUA
  MIEU
}

enum SpecialtyCategory {
  MON_AN
  TRAI_CAY
  QUA_MANG_VE
}

enum HistoricalSiteRank {
  CAP_QUOC_GIA
  CAP_TINH
  CHUA_XEP_HANG
}

enum AgricultureCategory {
  CAY_TRONG_CHU_LUC
  CHAN_NUOI
  THUY_LOI
  MO_HINH_SAN_XUAT
}

enum OcopCategory {
  THUC_PHAM
  DO_UONG
  NONG_SAN_TUOI
  SAN_PHAM_CHE_BIEN
}

enum OcopRating {
