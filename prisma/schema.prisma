// ---------- OCOP: One Commune One Product ----------

model OcopProduct {
  id           String       @id
  name         String       @db.VarChar(150)
  category     OcopCategory
  rating       OcopRating
  producer     String       @db.VarChar(150)
  address      String       @db.VarChar(255)
  priceRange   String       @db.VarChar(100)
  summary      String       @db.VarChar(300)
  description  Json
  highlights   Json
  contactNote  String       @db.VarChar(2000)
  contactPhone String?      @db.VarChar(30)
  mediaId      String?
  imageAlt     String       @default("") @db.VarChar(150)
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  version      Int          @default(1)
  createdById  String?
  updatedById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  media     Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("OcopProductCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("OcopProductUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder, createdAt])
  @@index([category, isActive, sortOrder])
  @@index([rating, isActive, sortOrder])
  @@index([name])
}

