  location    String              @db.VarChar(255)
  season      String              @db.VarChar(150)
  scale       String              @db.VarChar(150)
  summary     String              @db.VarChar(300)
  description Json
  highlights  Json
  support     String              @db.VarChar(2000)
  mediaId     String?
  imageAlt    String              @default("") @db.VarChar(150)
  sortOrder   Int                 @default(0)
  isActive    Boolean             @default(true)
  version     Int                 @default(1)
  createdById String?
  updatedById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  media     Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("AgricultureItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("AgricultureItemUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder, createdAt])
  @@index([category, isActive, sortOrder])
