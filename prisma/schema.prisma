  category        CuisineCategory
  priceRange      String          @db.VarChar(100)
  bestTime        String          @db.VarChar(100)
  suggestedPlaces Json
  summary         String          @db.VarChar(300)
  description     Json
  highlights      Json
  tip             String          @db.VarChar(2000)
  mediaId         String?
  imageAlt        String          @default("") @db.VarChar(150)
  sortOrder       Int             @default(0)
  isActive        Boolean         @default(true)
  version         Int             @default(1)
  createdById     String?
  updatedById     String?
