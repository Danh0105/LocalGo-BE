model ExperienceTour {
  id           String                 @id
  name         String                 @db.VarChar(150)
  category     ExperienceTourCategory
  duration     String                 @db.VarChar(100)
  startTime    String                 @db.VarChar(100)
  priceRange   String                 @db.VarChar(100)
  meetingPoint String                 @db.VarChar(255)
  summary      String                 @db.VarChar(300)
  description  Json
  itinerary    Json
  included     Json
  note         String                 @db.VarChar(2000)
  contactPhone String?                @db.VarChar(30)
  mediaId      String?
  imageAlt     String                 @default("") @db.VarChar(150)
  sortOrder    Int                    @default(0)
  isActive     Boolean                @default(true)
  version      Int                    @default(1)
  createdById  String?
  updatedById  String?
