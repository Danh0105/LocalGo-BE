  DI_TICH
  AM_THUC
  DICH_VU
}

enum ContactCategory {
  HANH_CHINH
  KHAN_CAP
  DU_LICH
  NONG_NGHIEP
  PHAN_ANH
}

enum NewsCategory {
  THONG_BAO
  HOAT_DONG_XA
  DU_LICH
  NONG_NGHIEP
  CHUYEN_DOI_SO
}

enum BusinessApplicantType {
  INDIVIDUAL
  ORGANIZATION
}

enum BusinessApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessDocumentType {
  IDENTITY_FRONT
  IDENTITY_BACK
  BUSINESS_LICENSE
  TAX_DOCUMENT
  OTHER
}

enum TradePostCategory {
  PRODUCT
  SERVICE
  BUY_REQUEST
  PROMOTION
}

enum TradePostPriceType {
  FIXED
  NEGOTIABLE
  CONTACT
}

enum TradePostStatus {
  DRAFT
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
  EXPIRED
  ARCHIVED
}

enum TradeReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

// ---------- Core / Auth ----------

model User {
  id           String     @id @default(uuid())
  zaloId       String?    @unique
  phone        String?    @unique
  email        String?    @unique
  displayName  String
  avatarUrl    String?
  passwordHash String?
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  authSessions                  AuthSession[]
  tradePostsOwned               TradePost[]           @relation("TradePostOwner")
  tradePostsApproved            TradePost[]           @relation("TradePostApprover")
  tradeReviews                  TradeReview[]
  mediaUploads                  Media[]
  auditLogs                     AuditLog[]
  businessApplicationsSubmitted BusinessApplication[] @relation("BusinessApplicationSubmitter")
  businessApplicationsReviewed  BusinessApplication[] @relation("BusinessApplicationReviewer")
  businessApplicationAccount    BusinessApplication?  @relation("BusinessApplicationAccount")
  aboutPagesCreated             AboutPage[]           @relation("AboutPageCreator")
  aboutPagesUpdated             AboutPage[]           @relation("AboutPageUpdater")
  aboutPagesPublished           AboutPage[]           @relation("AboutPagePublisher")
  aboutRevisionsPublished       AboutRevision[]       @relation("AboutRevisionPublisher")
  templesCreated                Temple[]              @relation("TempleCreator")
  templesUpdated                Temple[]              @relation("TempleUpdater")
  specialtiesCreated            Specialty[]           @relation("SpecialtyCreator")
  specialtiesUpdated            Specialty[]           @relation("SpecialtyUpdater")
  historicalSitesCreated        HistoricalSite[]      @relation("HistoricalSiteCreator")
  historicalSitesUpdated        HistoricalSite[]      @relation("HistoricalSiteUpdater")
  agricultureItemsCreated       AgricultureItem[]     @relation("AgricultureItemCreator")
  agricultureItemsUpdated       AgricultureItem[]     @relation("AgricultureItemUpdater")
  ocopProductsCreated           OcopProduct[]         @relation("OcopProductCreator")
  ocopProductsUpdated           OcopProduct[]         @relation("OcopProductUpdater")
  craftVillagesCreated          CraftVillage[]        @relation("CraftVillageCreator")
  craftVillagesUpdated          CraftVillage[]        @relation("CraftVillageUpdater")
  cuisineItemsCreated           CuisineItem[]         @relation("CuisineItemCreator")
  cuisineItemsUpdated           CuisineItem[]         @relation("CuisineItemUpdater")
  festivalsCreated              Festival[]            @relation("FestivalCreator")
  festivalsUpdated              Festival[]            @relation("FestivalUpdater")
  experienceToursCreated        ExperienceTour[]      @relation("ExperienceTourCreator")
  experienceToursUpdated        ExperienceTour[]      @relation("ExperienceTourUpdater")
  feedbackChannelsCreated       FeedbackChannel[]     @relation("FeedbackChannelCreator")
  feedbackChannelsUpdated       FeedbackChannel[]     @relation("FeedbackChannelUpdater")
  feedbackTicketsHandled        FeedbackTicket[]      @relation("FeedbackTicketHandler")
  mapPlacesCreated              MapPlace[]            @relation("MapPlaceCreator")
  mapPlacesUpdated              MapPlace[]            @relation("MapPlaceUpdater")
  contactsCreated               Contact[]             @relation("ContactCreator")
  contactsUpdated               Contact[]             @relation("ContactUpdater")
  newsArticlesCreated           NewsArticle[]         @relation("NewsArticleCreator")
  newsArticlesUpdated           NewsArticle[]         @relation("NewsArticleUpdater")

  @@index([role])
}

// Refresh-token rotation with reuse detection: one row per issuance,
// chained via familyId. Presenting an already-replaced token means the
// token was stolen/replayed -> revoke the whole family.
model AuthSession {
  id                String               @id @default(uuid())
  familyId          String
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash  String
  userAgent         String?
  ipAddress         String?
  issuedAt          DateTime             @default(now())
  expiresAt         DateTime
  replacedAt        DateTime?
  replacedByTokenId String?              @unique
  replacedBy        AuthSession?         @relation("SessionRotation", fields: [replacedByTokenId], references: [id])
  rotatedFrom       AuthSession?         @relation("SessionRotation")
  revokedAt         DateTime?
  revokedReason     SessionRevokeReason?
  createdAt         DateTime             @default(now())

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

// ---------- Shared taxonomy infra (used by future content domains; not wired to TradePost) ----------

model Category {
  id          String     @id @default(uuid())
  domain      String
  slug        String
  name        String
  description String?
  icon        String?
  parentId    String?
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryParent")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@unique([domain, slug])
  @@index([domain, isActive, sortOrder])
}

// ---------- Media ----------

model Media {
  id              String               @id @default(uuid())
  ownerId         String
  owner           User                 @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  storageProvider MediaStorageProvider @default(LOCAL)
  storageKey      String               @unique
  originalUrl     String
  thumbnailUrl    String?
  mimeType        String
  size            Int
  width           Int?
  height          Int?
  checksum        String
  resourceType    MediaResourceType?
  resourceId      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  tradePostImages              TradePostImage[]
  tradeReviewImages            TradeReviewImage[]
  businessApplicationDocuments BusinessApplicationDocument[]
  temples                      Temple[]
  specialties                  Specialty[]
  historicalSites              HistoricalSite[]
  agricultureItems             AgricultureItem[]
  ocopProducts                 OcopProduct[]
  craftVillages                CraftVillage[]
  cuisineItems                 CuisineItem[]
  festivals                    Festival[]
  experienceTours              ExperienceTour[]
  feedbackChannels             FeedbackChannel[]
  mapPlaces                    MapPlace[]
  contacts                     Contact[]
  newsArticles                 NewsArticle[]

  @@index([ownerId])
  @@index([resourceType, resourceId])
  @@index([checksum])
}

// ---------- Tourist points: temples / pagodas / shrines ----------

model Temple {
  id          String     @id
  name        String     @db.VarChar(150)
  type        TempleType
  address     String     @db.VarChar(255)
  openHours   String     @db.VarChar(100)
  summary     String     @db.VarChar(300)
  description Json
  mediaId     String?
  imageAlt    String     @default("") @db.VarChar(150)
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  version     Int        @default(1)
  createdById String?
  updatedById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  media     Media?        @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?         @relation("TempleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?         @relation("TempleUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  events    TempleEvent[]

  @@index([isActive, sortOrder, createdAt])
  @@index([type, isActive, sortOrder])
  @@index([name])
}

model TempleEvent {
  id        String   @id @default(uuid())
  templeId  String
  time      String   @db.VarChar(50)
  name      String   @db.VarChar(150)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  temple Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@index([templeId, sortOrder])
}

// ---------- Specialties: local food / fruit / gift products ----------

model Specialty {
  id          String            @id
  name        String            @db.VarChar(150)
  category    SpecialtyCategory
  price       String            @db.VarChar(100)
  season      String            @db.VarChar(100)
  summary     String            @db.VarChar(300)
  description Json
  buyPlaces   Json
  mediaId     String?
  imageAlt    String            @default("") @db.VarChar(150)
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  version     Int               @default(1)
  createdById String?
  updatedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  media     Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("SpecialtyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("SpecialtyUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder, createdAt])
  @@index([category, isActive, sortOrder])
  @@index([name])
}

// ---------- Historical sites: di tích lịch sử ----------

model HistoricalSite {
  id             String             @id
  name           String             @db.VarChar(150)
  rank           HistoricalSiteRank
  address        String             @db.VarChar(255)
  recognizedYear Int?
  summary        String             @db.VarChar(300)
  history        Json
  highlights     Json
  mediaId        String?
  imageAlt       String             @default("") @db.VarChar(150)
  sortOrder      Int                @default(0)
  isActive       Boolean            @default(true)
  version        Int                @default(1)
  createdById    String?
  updatedById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  media     Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("HistoricalSiteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("HistoricalSiteUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder, createdAt])
  @@index([rank, isActive, sortOrder])
  @@index([name])
}

// ---------- Agriculture: nông nghiệp ----------

model AgricultureItem {
  id          String              @id
  name        String              @db.VarChar(150)
