model MapPlace {
  id                 String           @id
  name               String           @db.VarChar(150)
  category           MapPlaceCategory
  address            String           @db.VarChar(255)
  lat                Decimal          @db.Decimal(9, 6)
  lng                Decimal          @db.Decimal(9, 6)
  openTime           String           @db.VarChar(150)
  distanceFromCenter String           @db.VarChar(100)
  summary            String           @db.VarChar(300)
  description        Json
  highlights         Json
  directionNote      String           @db.VarChar(2000)
  mediaId            String?
  imageAlt           String           @default("") @db.VarChar(150)
  sortOrder          Int              @default(0)
  isActive           Boolean          @default(true)
  version            Int              @default(1)
  createdById        String?
  updatedById        String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  media     Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("MapPlaceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("MapPlaceUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder, createdAt])
  @@index([category, isActive, sortOrder])
  @@index([name])
}

// ---------- Liên hệ ----------

model Contact {
  id            String          @id
  name          String          @db.VarChar(150)
  category      ContactCategory
  role          String          @db.VarChar(255)
  phone         String          @db.VarChar(30)
  email         String?         @db.VarChar(255)
  address       String          @db.VarChar(255)
  workingTime   String          @db.VarChar(150)
  summary       String          @db.VarChar(300)
  description   Json
  supportTopics Json
  note          String          @db.VarChar(2000)
  mediaId       String?
  imageAlt      String          @default("") @db.VarChar(150)
  sortOrder     Int             @default(0)
  isActive      Boolean         @default(true)
  version       Int             @default(1)
  createdById   String?
  updatedById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  media     Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("ContactCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("ContactUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder, createdAt])
  @@index([category, isActive, sortOrder])
  @@index([name])
}

// ---------- Tin tức ----------

model NewsArticle {
  id           String       @id
  title        String       @db.VarChar(200)
  category     NewsCategory
  publishedAt  DateTime
  author       String       @db.VarChar(150)
  summary      String       @db.VarChar(300)
  content      Json
  tags         Json
  relatedLinks Json
  mediaId      String?
  imageAlt     String       @default("") @db.VarChar(150)
  isActive     Boolean      @default(true)
  version      Int          @default(1)
  createdById  String?
  updatedById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  media     Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("NewsArticleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("NewsArticleUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, publishedAt])
  @@index([category, isActive, publishedAt])
  @@index([title])
}

// ---------- Business registration ----------

model BusinessApplication {
  id                  String                    @id @default(uuid())
  applicantType       BusinessApplicantType
  businessName        String
  businessCategory    String
  contactName         String
  contactPhone        String
  contactEmail        String
  address             String
  identityNumber      String?
  identityIssuedAt    DateTime?
  identityIssuedPlace String?
  legalName           String?
  taxCode             String?
  representativeName  String?
  representativeTitle String?
  website             String?
  description         String?
  status              BusinessApplicationStatus @default(PENDING)
  rejectionReason     String?
  submittedById       String?
  reviewedById        String?
  reviewedAt          DateTime?
  createdUserId       String?                   @unique
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  submittedBy User?                         @relation("BusinessApplicationSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedBy  User?                         @relation("BusinessApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdUser User?                         @relation("BusinessApplicationAccount", fields: [createdUserId], references: [id], onDelete: SetNull)
  documents   BusinessApplicationDocument[]

  @@index([status, createdAt])
  @@index([applicantType])
  @@index([contactEmail])
  @@index([taxCode])
  @@index([submittedById, createdAt])
}

model BusinessApplicationDocument {
  id            String               @id @default(uuid())
  applicationId String
  type          BusinessDocumentType
  name          String
  mediaId       String
  createdAt     DateTime             @default(now())

  application BusinessApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  media       Media               @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([applicationId, mediaId])
  @@index([applicationId])
}

// ---------- About page CMS ----------

model AboutPage {
  id                String    @id @default("about")
  draftSnapshot     Json
  publishedSnapshot Json?
  version           Int       @default(1)
  publishedVersion  Int       @default(0)
  createdById       String?
  updatedById       String?
  publishedById     String?
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdBy   User?           @relation("AboutPageCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?           @relation("AboutPageUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  publishedBy User?           @relation("AboutPagePublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  revisions   AboutRevision[]
}

model AboutRevision {
  id            String   @id @default(uuid())
  aboutPageId   String
  version       Int
  snapshot      Json
  publishedById String?
  publishedAt   DateTime @default(now())

  aboutPage   AboutPage @relation(fields: [aboutPageId], references: [id], onDelete: Cascade)
  publishedBy User?     @relation("AboutRevisionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  @@unique([aboutPageId, version])
  @@index([aboutPageId, publishedAt])
}

// ---------- TradePost ----------

model TradePost {
  id               String             @id @default(uuid())
  slug             String             @unique
  ownerId          String
  owner            User               @relation("TradePostOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  category         TradePostCategory
  title            String
  summary          String
  description      String
  priceType        TradePostPriceType
  price            Decimal?           @db.Decimal(14, 2)
  priceLabel       String?
  address          String
  lat              Decimal?           @db.Decimal(9, 6)
  lng              Decimal?           @db.Decimal(9, 6)
  contactName      String
  contactPhone     String
  contactZalo      String?
  thumbnailUrl     String?
  status           TradePostStatus    @default(DRAFT)
  featured         Boolean            @default(false)
  promotionPercent Int?
  promotionStartAt DateTime?
  promotionEndAt   DateTime?
  expiresAt        DateTime?
  viewCount        Int                @default(0)
  averageRating    Decimal            @default(0) @db.Decimal(2, 1)
  reviewCount      Int                @default(0)
  publishedAt      DateTime?
  rejectedReason   String?
  approvedById     String?
  approvedBy       User?              @relation("TradePostApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  images  TradePostImage[]
  reviews TradeReview[]

  @@index([status, publishedAt])
  @@index([ownerId])
  @@index([category])
  @@index([featured])
}

model TradePostImage {
  id          String    @id @default(uuid())
  tradePostId String
  tradePost   TradePost @relation(fields: [tradePostId], references: [id], onDelete: Cascade)
  mediaId     String
  media       Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([tradePostId, mediaId])
  @@index([tradePostId, sortOrder])
}

// ---------- TradeReview ----------

model TradeReview {
  id          String            @id @default(uuid())
  tradePostId String
  tradePost   TradePost         @relation(fields: [tradePostId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  rating      Int
  content     String            @db.VarChar(500)
  status      TradeReviewStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  images TradeReviewImage[]

  // True "one active review per user per post" is enforced via a hand-written
  // Postgres partial unique index (see migrations) — Prisma's schema DSL
  // cannot express a WHERE-filtered unique constraint. This index exists
  // for query-planning only.
  @@index([tradePostId, userId])
  @@index([tradePostId, status])
  @@index([userId])
}

model TradeReviewImage {
  id            String      @id @default(uuid())
  tradeReviewId String
  tradeReview   TradeReview @relation(fields: [tradeReviewId], references: [id], onDelete: Cascade)
  mediaId       String
  media         Media       @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())

  @@unique([tradeReviewId, mediaId])
}

// ---------- Audit ----------

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String?
  actor        User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action       String
  resourceType String
  resourceId   String?
  oldData      Json?
  newData      Json?
  ipAddress    String?
  userAgent    String?
  requestId    String?
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([actorId])
  @@index([createdAt])
  @@index([action])
}
