  FOUR
  FIVE
}

enum CraftVillageCategory {
  THU_CONG_TRUYEN_THONG
  CHE_BIEN_NONG_SAN
  DICH_VU_TRAI_NGHIEM
  SAN_PHAM_GIA_DINH
}

enum CuisineCategory {
  MON_NUOC
  MON_NUONG
  MON_CUON
  AN_VAT
  MON_CHAY
}

enum FestivalCategory {
  LE_TRUYEN_THONG
  VAN_HOA_CONG_DONG
  THE_THAO_VUI_CHOI
  SU_KIEN_NONG_SAN
