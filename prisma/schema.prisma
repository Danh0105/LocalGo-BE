// ---------- Phản hồi ----------

model FeedbackChannel {
  id           String                  @id
  title        String                  @db.VarChar(200)
  category     FeedbackChannelCategory
  responseTime String                  @db.VarChar(150)
  requiredInfo Json
  summary      String                  @db.VarChar(300)
  description  Json
  examples     Json
  note         String                  @db.VarChar(2000)
  mediaId      String?
  imageAlt     String                  @default("") @db.VarChar(150)
  sortOrder    Int                     @default(0)
  isActive     Boolean                 @default(true)
  version      Int                     @default(1)
  createdById  String?
  updatedById  String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  media     Media?           @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdBy User?            @relation("FeedbackChannelCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?            @relation("FeedbackChannelUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  tickets   FeedbackTicket[]

  @@index([isActive, sortOrder, createdAt])
  @@index([category, isActive, sortOrder])
  @@index([title])
}

model FeedbackTicket {
  id          String               @id @default(uuid())
  ticketCode  String               @unique
  channelId   String?
  fullName    String               @db.VarChar(150)
  phone       String               @db.VarChar(30)
  content     String               @db.VarChar(5000)
  status      FeedbackTicketStatus @default(NEW)
  adminNote   String?              @db.VarChar(2000)
  handledById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  resolvedAt  DateTime?

  channel   FeedbackChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  handledBy User?            @relation("FeedbackTicketHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([channelId])
  @@index([phone])
}

