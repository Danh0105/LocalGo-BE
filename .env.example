NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://localgo:localgo@localhost:5432/localgo

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:2999
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:3001
SWAGGER_ENABLED=true
MAX_IMAGE_SIZE_MB=5

BODY_LIMIT=1mb
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100

MEDIA_STORAGE_PROVIDER=local

ZALO_AUTH_MODE=mock

SEED_ADMIN_EMAIL=admin@localgo.local
SEED_ADMIN_PASSWORD=

# Optional: ID của ảnh đã upload dùng chung cho 6 điểm Đền - Chùa - Miếu seed.
TEMPLE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 4 di tích lịch sử seed.
HISTORICAL_SITE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 mục nông nghiệp seed.
AGRICULTURE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 sản phẩm OCOP seed.
OCOP_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 làng nghề seed.
CRAFT_VILLAGE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 món ẩm thực seed.
CUISINE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 lễ hội seed.
FESTIVAL_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 tour trải nghiệm seed.
EXPERIENCE_TOUR_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 kênh phản hồi seed.
FEEDBACK_CHANNEL_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 6 điểm bản đồ seed.
MAP_PLACE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 6 liên hệ seed.
CONTACT_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 bài tin tức seed.
NEWS_PLACEHOLDER_MEDIA_ID=
