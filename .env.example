NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://localgo:localgo@localhost:5432/localgo

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Allowlist CORS: địa chỉ nguồn được phép gọi API.
# - Local dev: http://localhost:* (các port phát triển frontend)
# - Zalo Mini App: https://h5.zadn.vn (bundle chính), https://h5.zdn.vn (resource wrapper)
# - Web/Admin: https://*.skilltripx.com.vn (domain production)
# Kiểm tra lại nếu domain thay đổi trước khi deploy production. Parse chính xác
# theo comma + trim, không dùng string pattern fuzzy. Mỗi origin được match toàn bộ.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:2999,https://h5.zadn.vn,https://h5.zdn.vn
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:3001
SWAGGER_ENABLED=true
MAX_IMAGE_SIZE_MB=5

BODY_LIMIT=1mb
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100

MEDIA_STORAGE_PROVIDER=local

# Zalo auth mode: 'mock' hoặc 'real'.
# - mock: Local development/test only. Chấp nhận token giả dạng mock:<zaloId>:<displayName>.
#   Không gọi Zalo, không cần ZALO_APP_SECRET. Dùng để test/dev mà không phụ thuộc Zalo API.
# - real: Production only. Verify token thật qua Zalo Graph API (graph.zalo.me).
#   Bắt buộc cấu hình ZALO_APP_SECRET bên dưới. Token sai/hết hạn trả 401.
#   Lỗi Zalo upstream trả 502. Tuyệt đối không được dùng 'mock' trên production.
ZALO_AUTH_MODE=mock

# Zalo Mini App "App Secret Key" — lấy từ Zalo Developers console.
# Bắt buộc khi ZALO_AUTH_MODE=real (validation fail fast nếu thiếu).
# Dùng để gọi graph.zalo.me/v2.0/me với access token từ client.
# KHÔNG log giá trị secret này, KHÔNG commit vào Git, lấy từ secret manager/env production.
# Kiểm tra xác nhận secret thuộc đúng Zalo App ID mà Mini App đang dùng.
ZALO_APP_SECRET=

SEED_ADMIN_EMAIL=admin@localgo.local
SEED_ADMIN_PASSWORD=

# Optional: ID của ảnh đã upload dùng chung cho 6 điểm Đền - Chùa - Miếu seed.
TEMPLE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 4 di tích lịch sử seed.
HISTORICAL_SITE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 mục nông nghiệp seed.
AGRICULTURE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 sản phẩm OCOP seed.
OCOP_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 làng nghề seed.
CRAFT_VILLAGE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 món ẩm thực seed.
CUISINE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 lễ hội seed.
FESTIVAL_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 tour trải nghiệm seed.
EXPERIENCE_TOUR_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 kênh phản hồi seed.
FEEDBACK_CHANNEL_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 6 điểm bản đồ seed.
MAP_PLACE_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 6 liên hệ seed.
CONTACT_PLACEHOLDER_MEDIA_ID=

# Optional: ID của ảnh đã upload dùng chung cho 5 bài tin tức seed.
NEWS_PLACEHOLDER_MEDIA_ID=
